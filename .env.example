# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
# For local: mongodb://localhost:27017/biome_ba
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/biome_ba?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/biome_ba
MONGO_DBNAME=biome_ba

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── ML Model ──────────────────────────────────────────────────────────────────
# Paths relative to the project root (d:\biome_ba\)
ML_MODEL_PATH=model_fp16.onnx
ML_CONFIG_PATH=config.json
# Set to true to defer model loading until first request (faster startup for dev)
ML_LAZY_LOAD=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100 per minute
RATE_LIMIT_IDENTIFY=10 per minute

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development.
CORS_ORIGINS=*
